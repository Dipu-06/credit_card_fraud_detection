     "text": [
      "ROC-AUC: 0.9440\n"
     ]
    }
   ],
   "source": [
    "model.eval()\n",
    "with torch.no_grad():\n",
    "    X_all_t    = torch.FloatTensor(X_scaled).to(device)\n",
    "    recon_all  = model(X_all_t).cpu().numpy()\n",
    "\n",
    "ae_scores = np.mean((X_scaled - recon_all) ** 2, axis=1)\n",
    "\n",
    "# Distribution: fraud should have higher error\n",
    "fig, ax = plt.subplots(figsize=(8, 4))\n",
    "ax.hist(ae_scores[y==0], bins=100, alpha=0.6, color='#1D9E75',\n",
    "        label='Normal', density=True)\n",
    "ax.hist(ae_scores[y==1], bins=100, alpha=0.8, color='#D85A30',\n",
    "        label='Fraud',  density=True)\n",
    "ax.set_xlabel('Reconstruction error (MSE)')\n",
    "ax.set_ylabel('Density')\n",
    "ax.set_title('Autoencoder reconstruction error — fraud vs normal')\n",
    "ax.legend(); plt.tight_layout(); plt.show()\n",
    "print(f'ROC-AUC: {roc_auc_score(y, ae_scores):.4f}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Threshold Tuning + Evaluation"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 11,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "\n",
      "── Isolation Forest ──\n",
      "ROC-AUC: 0.9504  |  Avg Precision: 0.1379  |  F1: 0.2598\n",
      "              precision    recall  f1-score   support\n",
      "\n",
      "      Normal       1.00      1.00      1.00    284315\n",
