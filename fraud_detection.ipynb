   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Preprocessing"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Training on 284,315 normal-only transactions\n",
      "Features: 29\n"
     ]
    }
   ],
   "source": [
    "df_clean = df.drop(columns=['Time'])\n",
    "df_clean['Amount'] = np.log1p(df_clean['Amount'])   # fix right skew\n",
    "\n",
    "X = df_clean.drop(columns=['Class']).values\n",
    "y = df_clean['Class'].values\n",
    "\n",
    "scaler   = StandardScaler()\n",
    "X_scaled = scaler.fit_transform(X)\n",
    "\n",
    "# ── KEY DESIGN CHOICE ──────────────────────────────────────────────────────\n",
    "# We pretend we have NO fraud labels. Train only on normal transactions.\n",
    "# This is the unsupervised assumption: in production you may have no labels.\n",
    "# ───────────────────────────────────────────────────────────────────────────\n",
    "X_train = X_scaled[y == 0]\n",
    "print(f'Training on {len(X_train):,} normal-only transactions')\n",
    "print(f'Features: {X_scaled.shape[1]}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Isolation Forest"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "IF flagged 636 transactions as fraud\n",
      "ROC-AUC: 0.9504\n"
     ]
    }
   ],
   "source": [
    "fraud_rate = 492 / 284807\n",
    "\n",
    "iso_forest = IsolationForest(\n",
    "    n_estimators=200,\n",
    "    contamination=fraud_rate,\n",
    "    random_state=SEED,\n",
    "    n_jobs=-1\n",
    ")\n",
    "iso_forest.fit(X_train)\n",
    "\n",
    "if_scores = -iso_forest.decision_function(X_scaled)  # flip: higher = more anomalous\n",
    "if_preds  = (iso_forest.predict(X_scaled) == -1).astype(int)\n",
    "\n",
    "print(f'IF flagged {if_preds.sum():,} transactions as fraud')\n",
    "print(f'ROC-AUC: {roc_auc_score(y, if_scores):.4f}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Autoencoder (PyTorch)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 9,
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 700x300 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Training complete\n"
     ]
    }
   ],
   "source": [
    "class Autoencoder(nn.Module):\n",
    "    def __init__(self, input_dim=29):\n",
    "        super().__init__()\n",
    "        self.encoder = nn.Sequential(\n",
    "            nn.Linear(input_dim, 20), nn.ReLU(),\n",
    "            nn.Linear(20, 14),        nn.ReLU(),\n",
    "            nn.Linear(14, 8),         nn.ReLU(),\n",
    "        )\n",
    "        self.decoder = nn.Sequential(\n",
    "            nn.Linear(8,  14),        nn.ReLU(),\n",
    "            nn.Linear(14, 20),        nn.ReLU(),\n",
    "            nn.Linear(20, input_dim),\n",
    "        )\n",
    "    def forward(self, x):\n",
    "        return self.decoder(self.encoder(x))\n",
    "\n",
    "device    = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n",
    "model     = Autoencoder(input_dim=29).to(device)\n",
    "optimizer = torch.optim.Adam(model.parameters(), lr=1e-3)\n",
    "criterion = nn.MSELoss()\n",
    "\n",
    "X_train_t = torch.FloatTensor(X_train).to(device)\n",
    "loader    = DataLoader(TensorDataset(X_train_t), batch_size=256, shuffle=True)\n",
    "\n",
    "losses = []\n",
    "for epoch in range(1, 31):\n",
    "    model.train()\n",
    "    total = 0\n",
    "    for (batch,) in loader:\n",
    "        recon = model(batch)\n",
    "        loss  = criterion(recon, batch)\n",
    "        optimizer.zero_grad(); loss.backward(); optimizer.step()\n",
    "        total += loss.item() * len(batch)\n",
    "    losses.append(total / len(X_train))\n",
    "\n",
    "plt.figure(figsize=(7, 3))\n",
    "plt.plot(losses, color='#D85A30', lw=2)\n",
    "plt.xlabel('Epoch'); plt.ylabel('MSE Loss')\n",
    "plt.title('Autoencoder training loss')\n",
    "plt.grid(alpha=0.3); plt.tight_layout(); plt.show()\n",
    "print('Training complete')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 10,
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
