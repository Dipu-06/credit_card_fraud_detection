      "              precision    recall  f1-score   support\n",
      "\n",
      "      Normal       1.00      1.00      1.00    284315\n",
      "       Fraud       0.52      0.53      0.53       492\n",
      "\n",
      "    accuracy                           1.00    284807\n",
      "   macro avg       0.76      0.77      0.76    284807\n",
      "weighted avg       1.00      1.00      1.00    284807\n",
      "\n"
     ]
    }
   ],
   "source": [
    "def evaluate(name, scores, y_true):\n",
    "    roc_auc = roc_auc_score(y_true, scores)\n",
    "    ap      = average_precision_score(y_true, scores)\n",
    "    prec, rec, thresholds = precision_recall_curve(y_true, scores)\n",
    "    f1s   = 2 * prec * rec / (prec + rec + 1e-8)\n",
    "    best  = np.argmax(f1s[:-1])\n",
    "    thresh = thresholds[best]\n",
    "    preds  = (scores >= thresh).astype(int)\n",
    "    print(f'\\n── {name} ──')\n",
    "    print(f'ROC-AUC: {roc_auc:.4f}  |  Avg Precision: {ap:.4f}  |  F1: {f1s[best]:.4f}')\n",
    "    print(classification_report(y_true, preds, target_names=['Normal', 'Fraud']))\n",
    "    return dict(name=name, roc_auc=roc_auc, ap=ap, f1=f1s[best],\n",
    "                prec=prec, rec=rec, scores=scores)\n",
    "\n",
    "r_if  = evaluate('Isolation Forest', if_scores,  y)\n",
    "r_ae  = evaluate('Autoencoder',      ae_scores,  y)"
